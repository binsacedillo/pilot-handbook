generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String           @id @default(uuid())
  clerkId         String           @unique
  email           String           @unique
  firstName       String?          @db.VarChar(100)
  lastName        String?          @db.VarChar(100)
  license         String?          @db.VarChar(50) // @deprecated - moving to PilotProfile
  licenseExpiry   DateTime?                         // @deprecated - moving to PilotProfile
  role            UserRole         @default(USER)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  aircraft        Aircraft[]
  flights         Flight[]
  userPreferences UserPreferences?
  pilotProfile    PilotProfile?
  safetySnapshots SafetySnapshot[]
}

model PilotProfile {
  id             String    @id @default(uuid())
  userId         String    @unique
  licenseNumber  String?   @db.VarChar(50)
  licenseType    String?   @db.VarChar(50)
  medicalClass   Int?      @default(3)
  medicalExpiry  DateTime?
  lastRestDate   DateTime?
  totalHoursGoal Float     @default(1500)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Aircraft {
  id           String   @id @default(uuid())
  make         String   @db.VarChar(100)
  model        String   @db.VarChar(100)
  registration String   @db.VarChar(20)
  imageUrl     String?
  status       String   @default("operational")
  flightHours  Float    @default(0)
  userId       String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isArchived   Boolean  @default(false)
  version      Int      @default(1)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  flights      Flight[]
  safetySnapshots SafetySnapshot[]

  @@unique([userId, registration])
}

model Flight {
  id             String   @id @default(uuid())
  date           DateTime
  departureCode  String   @db.VarChar(4)
  arrivalCode    String   @db.VarChar(4)
  duration       Float
  picTime        Float
  dualTime       Float
  landings       Int?     @default(1)
  remarks        String?  @db.VarChar(500)
  aircraftId     String
  userId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  dayLandings    Int      @default(0)
  nightLandings  Int      @default(0)
  isVerified     Boolean  @default(false)
  instructorName String?  @db.VarChar(100)
  signatureData  String?
  version        Int      @default(1)
  aircraft       Aircraft @relation(fields: [aircraftId], references: [id])
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

model UserPreferences {
  id                String     @id @default(cuid())
  userId            String     @unique
  darkMode          Boolean    @default(false)
  defaultAircraftId String?
  unitSystem        UnitSystem @default(METRIC)
  currency          String     @default("USD")
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  theme             Theme      @default(SYSTEM)
  favoriteAirport   String?    @default("KJFK")
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

model AuditLog {
  id         String      @id @default(uuid())
  userId     String
  action     AuditAction
  entityType String      @db.VarChar(50)
  entityId   String
  oldValues  Json?
  newValues  Json?
  changes    String?     @db.VarChar(500)
  ipAddress  String?     @db.VarChar(45)
  userAgent  String?     @db.VarChar(500)
  createdAt  DateTime    @default(now())

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@index([action])
}

enum UserRole {
  ADMIN
  PILOT
  USER
}

enum UnitSystem {
  METRIC
  IMPERIAL
}

enum Theme {
  LIGHT
  DARK
  SYSTEM
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  ROLE_CHANGE
  VERIFY
  UNVERIFY
}

model SafetySnapshot {
  id             String   @id @default(uuid())
  type           String   // 'DENSITY_ALTITUDE' | 'WEIGHT_BALANCE' | 'FUEL'
  userId         String
  aircraftId     String?
  inputs         Json
  results        Json
  calculatedAt   DateTime @default(now())
  status         String   // 'GO' | 'CAUTION' | 'NO_GO' | 'INVALID'
  reason         String?
  recommendation String?

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  aircraft       Aircraft? @relation(fields: [aircraftId], references: [id])

  @@index([userId, calculatedAt])
}
