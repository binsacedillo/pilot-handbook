############################################################
# Database Configuration
############################################################
# Prisma connection string (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/pilothandbook?schema=public"

############################################################
# Authentication (Clerk)
############################################################
NEXT_PUBLIC_CLERK_PUBLISHED_KEY=pk_test_placeholder
CLERK_SECRET_KEY=sk_test_placeholder
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
CLERK_WEBHOOK_SECRET=whsec_placeholder

############################################################
# Infrastructure & Rate Limiting
############################################################
# Upstash Redis (Rate limiting)
UPSTASH_REDIS_REST_URL="https://placeholder.upstash.io"
UPSTASH_REDIS_REST_TOKEN="placeholder_token"

############################################################
# External APIs
############################################################
# AVWX (Aviation weather data)
AVWX_API_KEY=placeholder_avwx_key

# Resend (Email delivery for feedback/contact)
RESEND_API_KEY=re_placeholder_resend_key

############################################################
# Deployment / Environment
############################################################
NODE_ENV=development
# NODE_TLS_REJECT_UNAUTHORIZED="0" # Optional: Dev only for self-signed certs
